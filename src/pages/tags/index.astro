---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Sidebar from '../../components/Sidebar';
import Page from '../../components/Page';
import siteMetadata from '../../data/siteMetadata.js';
import { getTagsList } from '../../utils/content';
import kebabCase from 'lodash/kebabCase';

const language = 'en';
const tags = await getTagsList(language);
const title = `Tags - ${siteMetadata.title}`;
const pathname = Astro.url.pathname;
---

<BaseLayout title={title} description={siteMetadata.subtitle} language={language}>
  <Sidebar
    client:load
    siteMetadata={siteMetadata}
    pathname={pathname}
    otherLanguagePath="/tags/ja"
  />
  <Page client:load title="Tags">
    <ul>
      {tags.map(tag => (
        <li>
          <a href={`/tag/${kebabCase(tag.fieldValue)}/`}>
            {tag.fieldValue} ({tag.totalCount})
          </a>
        </li>
      ))}
    </ul>
  </Page>
</BaseLayout>
